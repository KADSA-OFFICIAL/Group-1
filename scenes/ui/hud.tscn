[node name="NoticePanel" type="PanelContainer" parent="Root"]
visible = false
layout_mode = 1
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -300.0
offset_top = -96.0
offset_right = 300.0
offset_bottom = -24.0
